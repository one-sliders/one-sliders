  "history": [
    {
      "label": "1872",
      "text": "It was settled in 1872 by parish priest Antoine Labelle, leading to formal establishment of the parish in 1879."
    },
    {
      "label": "1892",
      "text": "A railway line from Montreal was completed to the village of Saint-Jovite in 1892, and extended to Lac Mercier in 1904."
    },
    {
      "label": "1905",
      "text": "In 1905 a hydroelectric dam was erected on the banks of the Ruisseau Clair (Clear River) and the Rivière-du-Diable (Devil's River) providing electricity initially for Saint-Jovite."
    },
    {
      "label": "1939",
      "text": "Constructed by Joseph Bondurant Ryan, the ski resort Mont-Tremblant Lodge began operation of their first chair lift in 1939."
    },
    {
      "label": "1965",
      "text": "His family sold the resort in 1965 to a consortium of investors."
    },
    {
      "label": "2002",
      "text": "In 2002 the four municipalities in the area merged, Ville Saint-Jovite, Paroisse de Saint-Jovite, Mont-Tremblant, and Lac-Tremblant-Nord, becoming the amalgamated Ville de Mont-Tremblant."
    }
  ],
